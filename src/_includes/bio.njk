---
layout: base.njk
---
<section class="py-5 bg-white">
    <div class="container">
        
        {# --- TOP HEADER & BACK LINK --- #}
        <div class="d-flex justify-content-end mb-4">
            <a href="/team" class="text-decoration-none" style="color: #92c04d; font-weight: 500;">
                &larr; Meet The Team
            </a>
        </div>

        <div class="text-center mb-5">
            <h1 class="display-6 fw-bold mb-1" style="color: #333;">{{ title }}</h1>
            <p class="fs-5 text-muted">{{ role }}</p>
        </div>

        {# --- TWO COLUMN BIO SECTION --- #}
        <div class="row g-5 align-items-start mb-5 pb-4">
            <div class="col-md-4">
                {% if image %}
                    <img src="{{ image }}" alt="{{ title }}" class="img-fluid bio-page-image shadow-sm">
                {% endif %}
            </div>

            <div class="col-md-8">
                <div class="bio-content" style="font-size: 1.05rem; line-height: 1.7; color: #4a4a4a;">
                    {{ content | safe }}
                </div>
            </div>
        </div>

        {# --- THERAPEUTIC APPROACHES --- #}
        {% if approaches and approaches.length > 0 %}
        <div class="text-center mb-5 pb-5">
            <h3 class="fw-semibold mb-4" style="color: #666;">Therapeutic Approaches</h3>
            
            {# Added a standard container here instead of a restricted max-width #}
            <div class="container">
                <div class="row g-3 justify-content-center">
                    {% for item in approaches %}
                    <div class="col-6 col-md-4 col-lg-3 d-flex">
                        
                        {# Adjusted to match your teal theme and exact padding/sizing #}
                        <div class="w-100 p-3 text-center d-flex align-items-center justify-content-center border bg-white" 
                             style="
                                border-color: #3b8e88 !important;
                                color: #3b8e88;
                                border-radius: 8px;
                                font-size: 0.95rem;
                                font-weight: 500;
                                min-height: 80px;
                                transition: all 0.2s ease-in-out;
                             ">
                            {{ item }}
                        </div>
                        
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
        {% endif %}

    </div>
</section>

{# --- FULL WIDTH TEAL BANNER --- #}
<div class="container-fluid py-4 text-center text-white" style="background-color: #3b8e88;">
    <h2 class="fw-semibold m-0">Schedule a Session With {{ title.split(" ")[0] }}</h2>
</div>

{# --- MINIMALIST CONTACT FORM --- #}
<section class="py-5 bg-white">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">

        <form id="bioContactForm" class="mt-3">
          <input type="hidden" name="therapist_email" value="{{ email }}">

          <div class="mb-4">
            <input type="text" class="form-control minimal-input" id="bio-name" name="name" placeholder="Contact name" required>
          </div>

          <div class="mb-4">
            <input type="tel" class="form-control minimal-input" id="bio-phone" name="phone" placeholder="Phone">
          </div>

          <div class="mb-4">
            <input type="email" class="form-control minimal-input" id="bio-email" name="email" placeholder="E-mail" required>
          </div>

          <div class="mb-5">
            <input type="text" class="form-control minimal-input" id="bio-message" name="message" placeholder="Let's talk" required>
          </div>

          <!-- Turnstile widget -->
          <div style="max-width: 300px;">
            <div class="cf-turnstile mb-4" data-sitekey="0x4AAAAAADBTgmkyOA3eOEqs" data-theme="light"></div>
          </div>

          <div id="bio-form-status" class="mb-3" role="alert" aria-live="polite"></div>

          <div class="text-center">
            <button type="submit" id="bio-submit-btn" class="btn btn-dark-green w-100 mb-3">Submit</button>
            <p class="small text-muted" style="font-size: 0.8rem; max-width: 400px; margin: 0 auto;">
              After submitting, please add our email address to your safe senders list to ensure our reply reaches you. If you haven't heard back within 3 business days, please check your spam or junk folder.
            </p>
          </div>
        </form>

        <script>
          document.getElementById('bioContactForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('bio-submit-btn');
            const status = document.getElementById('bio-form-status');
            btn.disabled = true;
            btn.textContent = 'Sending...';
            status.innerHTML = '';
            const formData = new FormData(this);
            try {
              const res = await fetch('/api/submit', {
                method: 'POST',
                body: formData
              });
              const data = await res.json();
              if (data.ok) {
                this.reset();
                if (window.turnstile) window.turnstile.reset();
                status.innerHTML = '<div class="alert alert-success">Thank you! We\'ll be in touch within 3 business days.</div>';
                btn.textContent = 'Sent!';
              } else {
                status.innerHTML = '<div class="alert alert-danger">Something went wrong. Please try again or call us directly.</div>';
                btn.disabled = false;
                btn.textContent = 'Submit';
                if (window.turnstile) window.turnstile.reset();
              }
            } catch(err) {
              status.innerHTML = '<div class="alert alert-danger">Network error. Please check your connection and try again.</div>';
              btn.disabled = false;
              btn.textContent = 'Submit';
              if (window.turnstile) window.turnstile.reset();
            }
          });
        </script>

      </div>
    </div>
  </div>
</section>