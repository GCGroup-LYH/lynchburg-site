---
layout: base.njk
---
<section class="py-5 bg-white">
    <div class="container">
        
        {# --- TOP HEADER & BACK LINK --- #}
        <div class="d-flex justify-content-end mb-4">
            <a href="/team" class="text-decoration-none" style="color: #92c04d; font-weight: 500;">
                &larr; Meet The Team
            </a>
        </div>

        <div class="text-center mb-5">
            <h1 class="display-6 fw-bold mb-1" style="color: #333;">{{ title }}</h1>
            <p class="fs-5 text-muted">{{ role }}</p>
        </div>

        {# --- TWO COLUMN BIO SECTION --- #}
        <div class="row g-5 align-items-start mb-5 pb-4">
            <div class="col-md-4">
                {% if image %}
                    <img src="{{ image }}" alt="{{ title }}" class="img-fluid bio-page-image shadow-sm">
                {% endif %}
            </div>

            <div class="col-md-8">
                <div class="bio-content" style="font-size: 1.05rem; line-height: 1.7; color: #4a4a4a;">
                    {{ content | safe }}
                </div>
            </div>
        </div>

        {# --- THERAPEUTIC APPROACHES --- #}
        {% if approaches and approaches.length > 0 %}
        <div class="text-center mb-5 pb-5">
            <h3 class="fw-semibold mb-4" style="color: #666;">Therapeutic Approaches</h3>
            
            <div class="row g-3 justify-content-center mx-auto" style="max-width: 1000px;">
                {% for item in approaches %}
                <div class="col-6 col-md-4 col-lg-3 d-flex">
                    
                    {# Matches your modular Modalities block perfectly #}
                    <div class="w-100 p-3 text-center d-flex align-items-center justify-content-center border bg-white border-warning text-warning" 
                         style="
                            border-radius: 8px;
                            font-size: 0.95rem;
                            font-weight: 500;
                            min-height: 80px;
                            transition: all 0.2s ease-in-out;
                         ">
                        {{ item }}
                    </div>
                    
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

    </div>
</section>

{# --- FULL WIDTH TEAL BANNER --- #}
<div class="container-fluid py-4 text-center text-white" style="background-color: #3b8e88;">
    <h2 class="fw-semibold m-0">Schedule a Session With {{ title.split(" ")[0] }}</h2>
</div>

{# --- MINIMALIST CONTACT FORM --- #}
<section class="py-5 bg-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                
                <form action="" method="POST" id="bioContactForm" class="mt-3">
                    {# Hidden email field for our future routing logic #}
                    <input type="hidden" name="therapist_email" value="{{ email }}">
                    
                    <div class="mb-4">
                        <input type="text" class="minimal-input" id="name" name="name" placeholder="Contact name" required>
                    </div>
                    
                    <div class="mb-4">
                        <input type="tel" class="minimal-input" id="phone" name="phone" placeholder="Phone">
                    </div>
                    
                    <div class="mb-4">
                        <input type="email" class="minimal-input" id="email" name="email" placeholder="E-mail" required>
                    </div>
                    
                    <div class="mb-5">
                        <input type="text" class="minimal-input" id="message" name="message" placeholder="Let's talk" required>
                    </div>
                    
                    <div class="text-center">
                        <button type="submit" class="btn btn-dark-green w-100 mb-3">Submit</button>
                        <p class="small text-muted" style="font-size: 0.8rem; max-width: 400px; margin: 0 auto;">
                            After submitting, please add our email address to your safe senders list to ensure our reply reaches you. If you haven't heard back within 3 business days, please check your spam or junk folder.
                        </p>
                    </div>
                </form>

            </div>
        </div>
    </div>
</section>