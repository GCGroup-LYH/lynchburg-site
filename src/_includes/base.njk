<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% if title == "Component Library" %}
        <meta name="robots" content="noindex, nofollow">
    {% endif %}

    <title>{{ title }} | {{ site.name }}</title>
    
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="icon" type="image/png" href="/assets/images/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/assets/images/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/assets/images/favicon/site.webmanifest" />
</head>
<body class="d-flex flex-column min-vh-100 {{ section_theme }}">
    <a href="#main-content" class="visually-hidden-focusable p-3 m-2 bg-primary text-white position-absolute z-3 rounded">
        Skip to main content
    </a>

    <nav class="navbar navbar-expand-lg bg-body border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
    {% if site.logo %}
        <img src="{{ site.logo }}" alt="{{ site.name }} Logo" style="max-height: 45px; width: auto;" class="d-inline-block align-text-middle">
    {% else %}
        <span class="fw-bold text-primary">{{ site.name }}</span>
    {% endif %}
</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    
                    {% for link in site.nav_links %}
                        <li class="nav-item">
                            <a class="nav-link {% if page.url == link.url %}active fw-bold{% endif %}" href="{{ link.url }}" {% if page.url == link.url %}aria-current="page"{% endif %}>{{ link.text }}</a>
                        </li>
                    {% endfor %}

                    <li class="nav-item dropdown ms-lg-3">
                    <a class="nav-link dropdown-toggle" href="#" id="a11yDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Accessibility Options">
                    <span aria-hidden="true">⚙️</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="a11yDropdown">
                        <li><button class="dropdown-item d-flex justify-content-between" onclick="toggleTheme()">Dark Mode <span id="theme-icon">🌙</span></button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item" onclick="changeFontSize(1)">Increase Text (A+)</button></li>
                        <li><button class="dropdown-item" onclick="changeFontSize(-1)">Decrease Text (A-)</button></li>
                        <li><button class="dropdown-item" onclick="resetFontSize()">Reset Text</button></li>
                    </ul>
                    </li>

                    <li class="nav-item ms-lg-3">
                        <a href="{{ site.practiceLink }}" class="btn {{ site.portal_btn_color | default('btn-primary') }}">Client Portal</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main id="main-content" class="flex-grow-1">
        {{ content | safe }}

        {% if sections %}
            {% for block in sections %}
            
                {% if block.type == "hero_home" %}
<section class="hero-home d-flex flex-column justify-content-center align-items-center position-relative {{ block.section_theme | default('bg-light') }}" style="min-height: 90vh; padding-bottom: 80px;">    
    <div class="container text-center z-2">

        {# Lottie Animation #}
        <div id="lottie-container" data-animation-path="{{ block.lottie_file }}" style="max-width: 500px; width: 60%; margin: 0 auto 2rem;"></div>
        {# Headline — fades in after animation completes #}
        <div id="hero-text" class="hero-fade-in" style="animation-delay: 7.1s;">
            <h1 class="display-5 fw-bold mb-3" style="color: #2c5e3b;">{{ block.headline | default('Growth starts here.') }}</h1>
            <p class="lead text-muted mb-4" style="font-size: 1.1rem;">{{ block.subtext | default('Professional counseling for individuals, couples, and families in Lynchburg, VA.') }}</p>
        </div>

        {# Buttons — fades in slightly after headline #}
        <div id="hero-buttons" class="hero-fade-in d-flex gap-3 justify-content-center" style="animation-delay: 7.5s;">
            <a href="{{ block.btn_1_link }}" class="btn btn-danger text-white px-4 py-2">{{ block.btn_1_text }}</a>
            <a href="{{ block.btn_2_link }}" class="btn btn-outline-danger bg-white px-4 py-2">{{ block.btn_2_text }}</a>
        </div>

    </div>

    {# Scroll Cue #}
    <div id="scroll-cue" class="hero-fade-in position-absolute bottom-0 start-50 translate-middle-x mb-3 text-center" style="animation-delay: 7.9s; pointer-events: none;">
        <span class="d-block text-success small mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">SCROLL</span>
        <div style="height: 20px; width: 1px; margin: 0 auto;" class="bg-success"></div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js"></script>
    <script>
        window.addEventListener('load', function() {
            var container = document.getElementById('lottie-container');
            if (!container) return;
            var path = container.getAttribute('data-animation-path');
            if (path) {
                var anim = lottie.loadAnimation({
                    container: container,
                    renderer: 'svg',
                    loop: false,
                    autoplay: true,
                    path: path
                });
                anim.setSpeed(0.75);
            }
        });
    </script>
</section>

<style>
    .hero-fade-in {
        opacity: 0;
        transform: translateY(12px);
        animation: heroFadeUp 0.8s ease forwards;
    }
    @keyframes heroFadeUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

    {% elif block.type == "hero_inner" %}
<section class="hero-inner d-flex align-items-center py-5 {{ block.section_theme | default('bg-light text-dark') }}" 
    style="
        min-height: 40vh;
        {% if block.bg_image and block.bg_type == 'photo' %}
        background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{ block.bg_image }}');
        background-size: cover;
        background-position: center;
        color: white !important;
        {% elif block.bg_image and block.bg_type == 'logo' %}
        background-image: url('{{ block.bg_image }}');
        background-size: contain;
        background-position: center;
        background-repeat: no-repeat;
        {% endif %}
    ">
    <div class="container text-center z-2 position-relative">
        <div class="row justify-content-center">
            <div class="col-lg-8 py-5">
                {% if block.headline %}
                <h1 class="display-4 fw-bold mb-3 {{ block.icon_color | default('') }}">{{ block.headline }}</h1>
                {% endif %}
                {% if block.subtext %}
                <p class="lead opacity-80 mb-0">{{ block.subtext }}</p>
                {% endif %}
            </div>
        </div>
    </div>
</section>

                {% elif block.type == "cta" %}
                    <section class="cta-block py-4 {{ block.section_theme }}">
                        <div class="container d-md-flex align-items-center justify-content-between text-center">
                            <h2 class="mb-3 mb-md-0">{{ block.text }}</h2>
                            <a href="{{ block.btn_link | default('/contact') }}" class="btn {{ block.btn_color | default('btn-outline-light') }} btn-lg">
                                {{ block.btn_text | default('Contact Us') }}
                            </a>
                        </div>
                    </section>

                {% elif block.type == "features" %}
                <section class="features-block py-5 {{ block.section_theme | default('bg-body') }}">
                    <div class="container">
                        {% if block.title %}
                            <h2 class="text-center mb-5 fw-semibold" style="color: #3b5249;">{{ block.title }}</h2>
                        {% endif %}
                        
                        {# col-lg-3 creates the 4-column layout from your Figma design #}
                        <div class="row g-4 justify-content-center">
                            {% for card in block.card_list %}
                            <div class="col-md-6 col-lg-3">
                                
                                {# The Wrapper bounds the grid space #}
                                <div class="card-wrapper position-relative h-100">
                                    
                                    {# 1. THE GHOST: Invisible structure to keep the row height from collapsing #}
                                    <div class="card border-0 p-4 invisible h-100">
                                        <h3 class="h6 mb-2">{{ card.name }}</h3>
                                        <p class="card-text small mb-0">{{ card.desc }}</p>
                                    </div>

                                    {# 2. THE REAL CARD: Positioned over the ghost, allowed to grow on hover #}
                                    <div class="card border-0 shadow-sm p-4 hover-expand-card position-absolute top-0 start-0 w-100" style="border-radius: 10px;">
                                        <h3 class="h6 mb-3 fw-semibold text-dark">{{ card.name }}</h3>
                                        <p class="card-text text-muted small mb-0 lh-sm">{{ card.desc }}</p>
                                        
                                        {% if card.expanded_desc %}
                                        <div class="expanded-content">
                                            <div class="expanded-inner">
                                                <hr class="my-3 opacity-25">
                                                <p class="card-text text-muted small mb-0 lh-sm">{{ card.expanded_desc }}</p>
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                    
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>

                    <style>
                        /* Base card styling */
                        .hover-expand-card {
                            height: 100%; /* Matches ghost height initially */
                            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
                            z-index: 1;
                            background: #ffffff;
                        }
                        
                        /* The CSS Grid animation trick for smooth expanding text */
                        .expanded-content {
                            display: grid;
                            grid-template-rows: 0fr;
                            transition: grid-template-rows 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
                            overflow: hidden;
                        }
                        .expanded-inner {
                            min-height: 0; /* Required for the grid animation to work */
                        }
                        
                        /* HOVER MAGIC */
                        .card-wrapper:hover .hover-expand-card {
                            height: auto; /* Allows it to break out of its container */
                            min-height: 100%;
                            z-index: 10;
                            box-shadow: 0 1rem 2.5rem rgba(0,0,0,0.12) !important;
                            transform: scale(1.03); /* Subtle pop forward */
                        }
                        .card-wrapper:hover .expanded-content {
                            grid-template-rows: 1fr; /* Opens the hidden text drawer */
                        }
                    </style>
                </section>

                 
{% elif block.type == 'faq' %}
<section class="faq-block py-5 {{ block.section_theme | default('bg-body') }}">
    <div class="container">
        <h2 class="text-center mb-5">{{ block.title }}</h2>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                {# Notice the unique IDs to make the toggles work perfectly #}
                <div class="accordion shadow-sm" id="faqAccordion">
                    {% for item in block.faq_list %}
                    <div class="accordion-item border-0 border-bottom">
                        <h3 class="accordion-header" id="heading-{{ loop.index }}">
                            <button class="accordion-button {% if not loop.first %}collapsed{% endif %} bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-{{ loop.index }}">
                                <strong>{{ item.question }}</strong>
                            </button>
                        </h3>
                        <div id="collapse-{{ loop.index }}" class="accordion-collapse collapse {% if loop.first %}show{% endif %}" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                {{ item.answer }}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

{% elif block.type == "info_highlights" %}
<section class="info-highlights-block py-5 {{ block.section_theme | default('bg-body') }}">
    <div class="container">

        {% if block.title %}
        <h2 class="text-center mb-5 fw-semibold">{{ block.title }}</h2>
        {% endif %}

        <div class="row g-4 justify-content-center text-center">

            {% for card in [block.card_1, block.card_2, block.card_3] %}
            {% if card and card.heading %}
            <div class="col-md-4">
                <div class="info-highlight-card px-4 py-3 h-100 d-flex flex-column align-items-center">
                    <div class="info-icon-box mb-4">
                        <i class="bi bi-{{ card.icon }} {{ card.icon_color | default('text-primary') }}" style="font-size: 1.75rem; line-height: 1;" aria-hidden="true"></i>
                    </div>
                    <h3 class="h5 fw-semibold mb-3">{{ card.heading }}</h3>
                    <p class="text-muted mb-4" style="font-size: 0.95rem; max-width: 280px;">{{ card.desc }}</p>
                    {% if card.link_text and card.link_url %}
                    <div class="mt-auto">
                        <a href="{{ card.link_url }}" class="info-highlight-link">{{ card.link_text }}</a>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}
            {% endfor %}

        </div>
    </div>
</section>

{% elif block.type == "contact_layout" %}
<section class="contact-layout-block py-5 {{ block.section_theme | default('bg-body') }}">
    <div class="container">
        <div class="row g-5 align-items-start">

            {# LEFT COLUMN — Rich Text #}
            <div class="col-md-5">
                {% if block.heading %}
                <h2 class="h4 fw-semibold mb-4" style="color: #333;">{{ block.heading }}</h2>
                {% endif %}
                <div class="text-muted" style="font-size: 0.95rem; line-height: 1.8;">
                    {{ block.body | markdown | safe }}
                </div>
            </div>

            {# RIGHT COLUMN — Contact Form #}
            <div class="col-md-7">
                <form id="contactLayoutForm" class="custom-minimal-form">
                    <input type="hidden" name="form_type" value="{{ block.route_to }}">

                    <div class="mb-4">
                        <label for="cl-name" class="visually-hidden">Contact name</label>
                        <input type="text" class="form-control minimal-input" id="cl-name" name="name" placeholder="Contact name" required>
                    </div>

                    <div class="mb-4">
                        <label for="cl-phone" class="visually-hidden">Phone</label>
                        <input type="tel" class="form-control minimal-input" id="cl-phone" name="phone" placeholder="Phone">
                    </div>

                    <div class="mb-4">
                        <label for="cl-email" class="visually-hidden">E-mail</label>
                        <input type="email" class="form-control minimal-input" id="cl-email" name="email" placeholder="E-mail" required>
                    </div>

                    <div class="mb-4">
                        <label for="cl-message" class="visually-hidden">Let's talk</label>
                        <textarea class="form-control minimal-input" id="cl-message" name="message" placeholder="Let's talk" rows="1" required></textarea>
                    </div>

                    <div style="max-width: 300px;">
                        <div class="cf-turnstile mb-4" data-sitekey="0x4AAAAAADBTgmkyOA3eOEqs" data-theme="light"></div>
                    </div>

                    <div id="cl-form-status" class="mb-3" role="alert" aria-live="polite"></div>

                    <button type="submit" id="cl-submit-btn" class="btn btn-{{ block.button_color | default('danger') }} w-100 py-3 rounded-2 fw-bold">
                        Submit
                    </button>

                    {% if block.disclaimer %}
                    <p class="small text-muted mt-3" style="font-size: 0.8rem;">{{ block.disclaimer }}</p>
                    {% endif %}
                </form>

                <script>
                    document.getElementById('contactLayoutForm').addEventListener('submit', async function(e) {
                        e.preventDefault();
                        const btn = document.getElementById('cl-submit-btn');
                        const status = document.getElementById('cl-form-status');
                        btn.disabled = true;
                        btn.textContent = 'Sending...';
                        status.innerHTML = '';
                        const formData = new FormData(this);
                        try {
                            const res = await fetch('/api/submit', {
                                method: 'POST',
                                body: formData
                            });
                            const data = await res.json();
                            if (data.ok) {
                                this.reset();
                                if (window.turnstile) window.turnstile.reset();
                                status.innerHTML = '<div class="alert alert-success">Thank you! We\'ll be in touch within 3 business days.</div>';
                                btn.textContent = 'Sent!';
                            } else {
                                status.innerHTML = '<div class="alert alert-danger">Something went wrong. Please try again or call us directly.</div>';
                                btn.disabled = false;
                                btn.textContent = 'Submit';
                                if (window.turnstile) window.turnstile.reset();
                            }
                        } catch(err) {
                            status.innerHTML = '<div class="alert alert-danger">Network error. Please check your connection and try again.</div>';
                            btn.disabled = false;
                            btn.textContent = 'Submit';
                            if (window.turnstile) window.turnstile.reset();
                        }
                    });
                </script>
            </div>

        </div>
    </div>
</section>

{% elif block.type == 'team' %}
<section class="team-block py-5 {{ block.section_theme | default('bg-light') }}">
    <div class="container">
        <h2 class="text-center mb-5">{{ block.title | default('Our Therapists') }}</h2>

        {% if collections.team and collections.team.length > 0 %}
            {% set team_by_type = collections.team | groupby("data.clinician_type") %}

            {# --- TOP SECTION: THERAPISTS --- #}
            <div class="row g-4">
                {% for person in team_by_type["Therapist"] %}
                <div class="{% if block.card_style == 'compact' %}col-md-4 col-lg-3{% else %}col-12{% endif %}">
                    <div class="card therapist-card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">

                        {% if block.card_style == 'compact' %}
                            {# --- COMPACT CARD --- #}
                            {% set compact_img = person.data.thumbnail if person.data.thumbnail else person.data.image %}
                            {% if compact_img %}
                            <img src="{{ compact_img }}" alt="{{ person.data.title }}" class="therapist-photo" style="height: 200px; object-position: top center;">
                            {% endif %}
                            <div class="card-body d-flex flex-column p-3 text-center">
                                <h3 class="h5 mb-0 fw-bold">{{ person.data.title }}</h3>
                                <p class="text-muted small mb-3">{{ person.data.role }}</p>
                                <p class="text-muted mb-3" style="font-size: 0.85rem;">{{ person.data.short_bio }}</p>
                                <div class="mt-auto">
                                    <a href="{{ person.url }}" class="therapist-link">
                                        Meet {{ person.data.title | split(" ") | first }} &rarr;
                                    </a>
                                </div>
                            </div>

                        {% else %}
                            {# --- FULL HORIZONTAL CARD --- #}
                            <div class="row g-0 align-items-stretch">
                                <div class="col-md-4">
                                    {% if person.data.image %}
                                    <img src="{{ person.data.image }}" alt="{{ person.data.title }}" class="therapist-photo-horizontal"
     style="width: 100%; height: 100%; object-fit: cover; object-position: top center; min-height: 300px;">
                                    {% endif %}
                                </div>
                                <div class="col-md-8">
                                    <div class="card-body d-flex flex-column p-4 p-lg-5 h-100 text-start">
                                        {% if person.data.quote %}
                                        <p class="therapist-quote mb-0">{{ person.data.quote }}</p>
                                        <hr class="therapist-divider">
                                        {% endif %}
                                        <h3 class="h4 mb-0 fw-bold">{{ person.data.title }}</h3>
                                        <p class="text-dark small fw-semibold mb-3">{{ person.data.role }}</p>
                                        <div class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.7;">
                                            {{ person.templateContent | safe }}
                                        </div>
                                        <div class="mt-auto">
                                            <a href="{{ person.url }}" class="therapist-link">
                                                Meet {{ person.data.title | split(" ") | first }} &rarr;
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                    </div>
                </div>
                {% endfor %}
            </div>

            {# --- BOTTOM SECTION: RESIDENT CLINICIANS (CONDITIONAL) --- #}
            {% if block.show_residents and team_by_type["Resident Clinician"] and team_by_type["Resident Clinician"].length > 0 %}
            
            <div class="row mt-5 mb-4 justify-content-center">
                <div class="col-12 text-center text-white p-5 rounded shadow-sm" style="background-color: #3b8e88;">
                    <h2 class="fw-bold mb-2">Resident Clinicians</h2>
                    <p class="lead mb-0 opacity-75" style="font-size: 1.1rem;">Supervised student clinicians completing their graduate training under licensed supervision.</p>
                </div>
            </div>

            <div class="row g-4">
                {% for person in team_by_type["Resident Clinician"] %}
                <div class="{% if block.card_style == 'compact' %}col-md-4 col-lg-3{% else %}col-12{% endif %}">
                    <div class="card therapist-card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">

                        {% if block.card_style == 'compact' %}
                            {# --- COMPACT CARD --- #}
                            {% set compact_img = person.data.thumbnail if person.data.thumbnail else person.data.image %}
                            {% if compact_img %}
                            <img src="{{ compact_img }}" alt="{{ person.data.title }}" class="therapist-photo" style="height: 200px; object-position: top center;">
                            {% endif %}
                            <div class="card-body d-flex flex-column p-3 text-center">
                                <h3 class="h5 mb-0 fw-bold">{{ person.data.title }}</h3>
                                <p class="text-muted small mb-3">{{ person.data.role }}</p>
                                <p class="text-muted mb-3" style="font-size: 0.85rem;">{{ person.data.short_bio }}</p>
                                <div class="mt-auto">
                                    <a href="{{ person.url }}" class="therapist-link">
                                        Meet {{ person.data.title | split(" ") | first }} &rarr;
                                    </a>
                                </div>
                            </div>

                        {% else %}
                            {# --- FULL HORIZONTAL CARD --- #}
                            <div class="row g-0 align-items-stretch">
                                <div class="col-md-4">
                                    {% if person.data.image %}
                                    <img src="{{ person.data.image }}" alt="{{ person.data.title }}" class="therapist-photo-horizontal"
     style="width: 100%; height: 100%; object-fit: cover; object-position: top center; min-height: 300px;">
                                    {% endif %}
                                </div>
                                <div class="col-md-8">
                                    <div class="card-body d-flex flex-column p-4 p-lg-5 h-100 text-start">
                                        {% if person.data.quote %}
                                        <p class="therapist-quote mb-0">{{ person.data.quote }}</p>
                                        <hr class="therapist-divider">
                                        {% endif %}
                                        <h3 class="h4 mb-0 fw-bold">{{ person.data.title }}</h3>
                                        <p class="text-dark small fw-semibold mb-3">{{ person.data.role }}</p>
                                        <div class="text-muted mb-4" style="font-size: 0.95rem; line-height: 1.7;">
                                            {{ person.templateContent | safe }}
                                        </div>
                                        <div class="mt-auto">
                                            <a href="{{ person.url }}" class="therapist-link">
                                                Meet {{ person.data.title | split(" ") | first }} &rarr;
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                    </div>
                </div>
                {% endfor %}
            </div>
            {% endif %}

        {% else %}
            <div class="text-center py-5">
                <p class="lead text-muted">We are currently updating our staff directory. Please check back soon!</p>
            </div>
        {% endif %}
        
    </div>
</section>

{% elif block.type == 'rates' %}
<section class="rates-block py-5 {{ block.section_theme | default('bg-body') }}">
    <div class="container">
        <h2 class="text-center mb-5 fw-semibold text-dark">{{ block.title }}</h2>

        {% if block.intro %}
        <p class="text-center text-muted mb-5 mx-auto" style="max-width: 700px;">{{ block.intro }}</p>
        {% endif %}

        <div class="row g-4 justify-content-center">

            {# Left Card: Rates + CTA #}
