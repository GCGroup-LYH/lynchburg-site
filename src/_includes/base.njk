                <div id="carousel-{{ loop.index }}" class="carousel slide shadow rounded overflow-hidden" data-bs-ride="carousel">
                    
                    {# The Bottom Dots (Indicators) #}
                    <div class="carousel-indicators">
                        {% for slide in block.slide_list %}
                        <button type="button" data-bs-target="#carousel-{{ loop.parent.loop.index }}" data-bs-slide-to="{{ loop.index0 }}" class="{% if loop.first %}active{% endif %}" aria-current="{% if loop.first %}true{% endif %}"></button>
                        {% endfor %}
                    </div>

                    {# The Actual Images #}
                    <div class="carousel-inner">
                        {% for slide in block.slide_list %}
