<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% if title == "Component Library" %}
        <meta name="robots" content="noindex, nofollow">
    {% endif %}

    <title>{{ title }} | {{ site.name }}</title>
    
    <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body class="d-flex flex-column min-vh-100 {{ section_theme }}">
    <a href="#main-content" class="visually-hidden-focusable p-3 m-2 bg-primary text-white position-absolute z-3 rounded">
        Skip to main content
    </a>

    <nav class="navbar navbar-expand-lg bg-body border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/">{{ site.name }}</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    
                    {% for link in site.nav_links %}
                        <li class="nav-item">
                            <a class="nav-link {% if page.url == link.url %}active fw-bold{% endif %}" href="{{ link.url }}" {% if page.url == link.url %}aria-current="page"{% endif %}>{{ link.text }}</a>
                        </li>
                    {% endfor %}

                    <li class="nav-item dropdown ms-lg-3">
                    <a class="nav-link dropdown-toggle" href="#" id="a11yDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Accessibility Options">
                    <span aria-hidden="true">⚙️</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="a11yDropdown">
                        <li><button class="dropdown-item d-flex justify-content-between" onclick="toggleTheme()">Dark Mode <span id="theme-icon">🌙</span></button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item" onclick="changeFontSize(1)">Increase Text (A+)</button></li>
                        <li><button class="dropdown-item" onclick="changeFontSize(-1)">Decrease Text (A-)</button></li>
                        <li><button class="dropdown-item" onclick="resetFontSize()">Reset Text</button></li>
                    </ul>
                    </li>

                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-primary shadow-sm" href="{{ site.practiceLink }}" target="_blank">
                            Client Portal
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main id="main-content" class="flex-grow-1">
        {{ content | safe }}

        {% if sections %}
            {% for block in sections %}
            
                {% if block.type == "hero" %}
                    <section class="hero-block py-5 text-center" 
         {% if block.bg_image %}
         style="background-image: url('{{ block.bg_image }}'); background-size: cover; background-position: center;" 
         role="img" 
         aria-label="{{ block.alt }}"
         {% endif %}>
                        <div class="container py-5">
                            <h1 class="display-3 fw-bold">{{ block.headline }}</h1>
                            <p class="lead">{{ block.subtext }}</p>
                            <a href="{{ block.btn_link }}" class="btn btn-primary btn-lg">{{ block.btn_text }}</a>
                        </div>
                    </section>

                {% elif block.type == "cta" %}
                    <section class="cta-block py-4 {{ block.section_theme }}">
                        <div class="container d-md-flex align-items-center justify-content-between text-center">
                            <h2 class="mb-3 mb-md-0">{{ block.text }}</h2>
                            <a href="/contact" class="btn btn-outline-light btn-lg">Contact Us</a>
                        </div>
                    </section>

                {% elif block.type == "features" %}
                    <section class="features-block py-5 bg-light">
                        <div class="container">
                            <h2 class="text-center mb-5">{{ block.title }}</h2>
                            <div class="row g-4">
                                {% for card in block.card_list %}
                                    <div class="col-md-4">
                                        <div class="card h-100 border-0 shadow-sm text-center p-4">
                                            {% if card.icon %}<img src="{{ card.icon }}" class="mx-auto mb-3" style="width: 64px;" alt="{{ card.alt }}">{% endif %}
                                            <h3>{{ card.name }}</h3>
                                            <p>{{ card.desc }}</p>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </section>

                {% elif block.type == "split_block" %}
                    <section class="split-block py-5 {{ block.section_theme }}">
                        <div class="container">
                            <div class="row align-items-center">
                                {% if block.align == "Right" %}
                                    <div class="col-md-6 mb-4 mb-md-0">
                                        <h2>{{ block.heading }}</h2>
                                        <div>{{ block.body | safe }}</div> 
                                    </div>
                                    <div class="col-md-6">
                                        <img src="{{ block.image }}" class="img-fluid rounded shadow" alt="{{ block.alt }}">
                                    </div>
                                {% else %}
                                    <div class="col-md-6 order-md-2 mb-4 mb-md-0">
                                        <h2>{{ block.heading }}</h2>
                                        <div>{{ block.body | safe }}</div>
                                    </div>
                                    <div class="col-md-6 order-md-1">
                                        <img src="{{ block.image }}" class="img-fluid rounded shadow" alt="{{ block.alt }}">
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </section>

                {% elif block.type == "testimonials" %}
                    <section class="testimonials-block py-5 {{ block.section_theme }}">
                        <div class="container">
                            <h2 class="text-center mb-5">{{ block.title }}</h2>
                            <div class="row g-4 justify-content-center">
                                {% for review in block.review_list %}
                                    <div class="col-md-6 col-lg-4">
                                        <div class="card h-100 border-0 shadow-sm p-4 text-center bg-white text-dark">
                                            <div class="text-warning mb-3 fs-5">★★★★★</div>
                                            <blockquote class="blockquote mb-3">
                                                <p class="fs-6">"{{ review.quote }}"</p>
                                            </blockquote>
                                            <figcaption class="blockquote-footer mb-0">
                                                {{ review.author }} <cite title="Source Title">on Google</cite>
                                            </figcaption>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </section>

                {% endif %}

            {% endfor %}
        {% endif %}
    </main>

    <footer class="bg-dark text-white py-5 mt-auto">
        <div class="container text-center">
            
            {% if site.footer_links %}
            <ul class="list-inline mb-4">
                {% for link in site.footer_links %}
                    <li class="list-inline-item mx-3">
                        <a href="{{ link.url }}" class="text-white text-decoration-none border-bottom border-secondary pb-1">{{ link.text }}</a>
                    </li>
                {% endfor %}
            </ul>
            {% endif %}

            <p class="mb-2">&copy; 2026 {{ site.name }}</p>
            <p class="small text-white-50">
                {{ site.footer_text }} | 
                <a href="mailto:{{ site.contactEmail }}" class="text-white-50">{{ site.contactEmail }}</a> | 
                {{ site.phone }}
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // --- Dark Mode Logic ---
        function toggleTheme() {
            const htmlTag = document.documentElement;
            const currentTheme = htmlTag.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            htmlTag.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('siteTheme', newTheme);
            document.getElementById('theme-icon').textContent = newTheme === 'dark' ? '☀️' : '🌙';
        }

        // Apply saved theme on page load
        if (localStorage.getItem('siteTheme') === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
            document.getElementById('theme-icon').textContent = '☀️';
        }

        // --- Text Resizer Logic ---
        let currentSize = 16; // Base size in pixels
        const rootElement = document.documentElement;

        function changeFontSize(direction) {
            currentSize += (direction * 2); // Goes up or down by 2px
            // Cap the sizes so it doesn't break the layout
            if (currentSize > 24) currentSize = 24; 
            if (currentSize < 14) currentSize = 14; 
            
            rootElement.style.fontSize = currentSize + 'px';
            localStorage.setItem('siteFontSize', currentSize);
        }

        function resetFontSize() {
            currentSize = 16;
            rootElement.style.fontSize = '16px';
            localStorage.removeItem('siteFontSize');
        }

        // Apply saved font size on load
        const savedSize = localStorage.getItem('siteFontSize');
        if (savedSize) {
            currentSize = parseInt(savedSize);
            rootElement.style.fontSize = currentSize + 'px';
        }
    </script>
</body>
</html>