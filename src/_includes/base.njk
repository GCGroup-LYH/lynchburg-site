<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% if title == "Component Library" %}
        <meta name="robots" content="noindex, nofollow">
    {% endif %}

    <title>{{ title }} | {{ site.name }}</title>
    
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="d-flex flex-column min-vh-100 {{ section_theme }}">
    <a href="#main-content" class="visually-hidden-focusable p-3 m-2 bg-primary text-white position-absolute z-3 rounded">
        Skip to main content
    </a>

    <nav class="navbar navbar-expand-lg bg-body border-bottom sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/">{{ site.name }}</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    
                    {% for link in site.nav_links %}
                        <li class="nav-item">
                            <a class="nav-link {% if page.url == link.url %}active fw-bold{% endif %}" href="{{ link.url }}" {% if page.url == link.url %}aria-current="page"{% endif %}>{{ link.text }}</a>
                        </li>
                    {% endfor %}

                    <li class="nav-item dropdown ms-lg-3">
                    <a class="nav-link dropdown-toggle" href="#" id="a11yDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Accessibility Options">
                    <span aria-hidden="true">⚙️</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="a11yDropdown">
                        <li><button class="dropdown-item d-flex justify-content-between" onclick="toggleTheme()">Dark Mode <span id="theme-icon">🌙</span></button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><button class="dropdown-item" onclick="changeFontSize(1)">Increase Text (A+)</button></li>
                        <li><button class="dropdown-item" onclick="changeFontSize(-1)">Decrease Text (A-)</button></li>
                        <li><button class="dropdown-item" onclick="resetFontSize()">Reset Text</button></li>
                    </ul>
                    </li>

                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-primary shadow-sm" href="{{ site.practiceLink }}" target="_blank">
                            Client Portal
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main id="main-content" class="flex-grow-1">
        {{ content | safe }}

        {% if sections %}
            {% for block in sections %}
            
                {% if block.type == "hero" %}
                    <section class="hero-block py-5 text-center" 
         {% if block.bg_image %}
         style="background-image: url('{{ block.bg_image }}'); background-size: cover; background-position: center;" 
         role="img" 
         aria-label="{{ block.alt }}"
         {% endif %}>
                        <div class="container py-5">
                            <h1 class="display-3 fw-bold">{{ block.headline }}</h1>
                            <p class="lead">{{ block.subtext }}</p>
                            <a href="{{ block.btn_link }}" class="btn btn-primary btn-lg">{{ block.btn_text }}</a>
                        </div>
                    </section>

                {% elif block.type == "cta" %}
                    <section class="cta-block py-4 {{ block.section_theme }}">
                        <div class="container d-md-flex align-items-center justify-content-between text-center">
                            <h2 class="mb-3 mb-md-0">{{ block.text }}</h2>
                            <a href="/contact" class="btn btn-outline-light btn-lg">Contact Us</a>
                        </div>
                    </section>

                {% elif block.type == "features" %}
                    <section class="features-block py-5 bg-light">
                        <div class="container">
                            <h2 class="text-center mb-5">{{ block.title }}</h2>
                                <div class="row g-4">
                                 {% for card in block.card_list %}
                                 <div class="col-md-4">
                                    <div class="card h-100 border-0 shadow-sm text-center p-4">
                        
                        {# NEW BOOTSTRAP ICON LOGIC #}
                        {% if card.icon %}
                            <i class="{{ card.icon }} display-4 {{ card.icon_color | default('text-primary') }} mb-3" aria-hidden="true"></i>
                        {% endif %}
                        
                                <h3>{{ card.name }}</h3>
                                <p>{{ card.desc }}</p>
                             </div>
                             </div>
                            {% endfor %}
                        </div>
                     </div>
                    </section>

                 
{% elif block.type == 'faq' %}
<section class="faq-block py-5">
    <div class="container">
        <h2 class="text-center mb-5">{{ block.title }}</h2>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                {# Notice the unique IDs to make the toggles work perfectly #}
                <div class="accordion shadow-sm" id="faqAccordion">
                    {% for item in block.faq_list %}
                    <div class="accordion-item border-0 border-bottom">
                        <h3 class="accordion-header" id="heading-{{ loop.index }}">
                            <button class="accordion-button {% if not loop.first %}collapsed{% endif %} bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-{{ loop.index }}">
                                <strong>{{ item.question }}</strong>
                            </button>
                        </h3>
                        <div id="collapse-{{ loop.index }}" class="accordion-collapse collapse {% if loop.first %}show{% endif %}" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                {{ item.answer }}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

{% elif block.type == 'team' %}
<section class="team-block py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5">{{ block.title }}</h2>
        <div class="row g-4 justify-content-center">
            {% for member in block.member_list %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm text-center p-4">
                    {% if member.image %}
                    <img src="{{ member.image }}" alt="{{ member.name }}" class="rounded-circle mx-auto mb-3 object-fit-cover shadow-sm" style="width: 140px; height: 140px;">
                    {% endif %}
                    <h3 class="h4 mb-1">{{ member.name }}</h3>
                    {% if member.credentials %}<p class="text-primary fw-bold mb-3">{{ member.credentials }}</p>{% endif %}
                    <p class="text-muted mb-0" style="font-size: 0.95rem;">{{ member.bio }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% elif block.type == 'rates' %}
<section class="rates-block py-5">
    <div class="container">
        <h2 class="text-center mb-4">{{ block.title }}</h2>
        {% if block.intro %}
        <p class="text-center text-muted mb-5 mx-auto" style="max-width: 700px;">{{ block.intro }}</p>
        {% endif %}
        
        <div class="row g-5">
            {# Left Column: Rates Table #}
            <div class="col-md-7">
                <h3 class="h5 mb-4">Service Rates</h3>
                <div class="table-responsive shadow-sm rounded">
                    <table class="table table-hover align-middle mb-0 bg-white">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3 px-4">Service</th>
                                <th class="py-3 px-4 text-end">Fee</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for rate in block.rate_list %}
                            <tr>
                                <td class="py-3 px-4">{{ rate.service }}</td>
                                <td class="py-3 px-4 text-end fw-bold text-dark">{{ rate.price }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            
            {# Right Column: Insurance List #}
            <div class="col-md-5">
                <div class="card border-0 bg-light p-4 h-100 shadow-sm">
                    <h3 class="h5 mb-4">Accepted Insurance</h3>
                    <ul class="list-unstyled mb-0">
                        {% for item in block.insurance_list %}
                        <li class="mb-3 d-flex align-items-center">
                            {# We are using the bi-check-circle-fill icon here! #}
                            <i class="bi-check-circle-fill text-primary me-3 fs-5" aria-hidden="true"></i> 
                            <span class="text-dark fw-medium">{{ item.provider }}</span>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

                {% elif block.type == "split_block" %}
                    <section class="split-block py-5 {{ block.section_theme }}">
                        <div class="container">
                            <div class="row align-items-center">
                                {% if block.align == "Right" %}
                                    <div class="col-md-6 mb-4 mb-md-0">
                                        <h2>{{ block.heading }}</h2>
                                        <div>{{ block.body | safe }}</div> 
                                    </div>
                                    <div class="col-md-6">
                                        <img src="{{ block.image }}" class="img-fluid rounded shadow" alt="{{ block.alt }}">
                                    </div>
                                {% else %}
                                    <div class="col-md-6 order-md-2 mb-4 mb-md-0">
                                        <h2>{{ block.heading }}</h2>
                                        <div>{{ block.body | safe }}</div>
                                    </div>
                                    <div class="col-md-6 order-md-1">
                                        <img src="{{ block.image }}" class="img-fluid rounded shadow" alt="{{ block.alt }}">
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </section>

                    {% elif block.type == 'location' %}
<section class="location-block py-5 bg-white">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <h2 class="mb-4">{{ block.title }}</h2>
                <div class="d-flex mb-4">
                    <i class="bi-geo-alt-fill text-primary fs-3 me-3" aria-hidden="true"></i>
                    <div>
                        <h3 class="h5 mb-1">Address</h3>
                        {# 'white-space: pre-line' keeps the stakeholder's line breaks! #}
                        <p class="text-muted mb-0 fs-5" style="white-space: pre-line;">{{ block.address }}</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                {# The 'ratio ratio-16x9' classes force the iframe to be perfectly responsive! #}
                <div class="ratio ratio-16x9 shadow-sm rounded overflow-hidden">
                    {{ block.map_iframe | safe }}
                </div>
            </div>
        </div>
    </div>
</section>

{% elif block.type == 'rich_text' %}
<section class="rich-text-block py-5">
    <div class="container">
        <div class="row justify-content-center">
            {# We use col-lg-8 to constrain the width. Long lines of text are hard to read! #}
            <div class="col-lg-8">
                <div class="content-prose fs-5 text-muted">
                    {{ block.content | markdown | safe }}
                </div>
            </div>
        </div>
    </div>
</section>

{% elif block.type == 'divider' %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            {% if block.style == 'line' %}
                <hr class="text-muted opacity-25 my-5">
            {% else %}
                <div class="{{ block.style }}"></div>
            {% endif %}
        </div>
    </div>
</div>


{% elif block.type == 'carousel' %}
<section class="carousel-block py-5">
    <div class="container">
        {% if block.title %}
        <h2 class="text-center mb-5">{{ block.title }}</h2>
        {% endif %}
        
        <div class="row justify-content-center">
            <div class="col-lg-10">
                {# data-bs-ride="carousel" is the Bootstrap magic that makes it auto-slide #}
                <div id="carousel-{{ loop.index }}" class="carousel slide shadow rounded overflow-hidden" data-bs-ride="carousel">
                    
                    {# The Bottom Dots (Indicators) #}
                    <div class="carousel-indicators">
                        {% for slide in block.slide_list %}
                        <button type="button" data-bs-target="#carousel-{{ loop.parent.loop.index }}" data-bs-slide-to="{{ loop.index0 }}" class="{% if loop.first %}active{% endif %}" aria-current="{% if loop.first %}true{% endif %}"></button>
                        {% endfor %}
                    </div>

                    {# The Actual Images #}
                    <div class="carousel-inner">
                        {% for slide in block.slide_list %}
                        <div class="carousel-item {% if loop.first %}active{% endif %}">
                            <img src="{{ slide.image }}" class="d-block w-100 object-fit-cover" style="height: 500px;" alt="{{ slide.alt }}">
                            
                            {# Optional Captions #}
                            {% if slide.heading or slide.text %}
                            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded px-3 py-2 mb-4">
                                {% if slide.heading %}<h5>{{ slide.heading }}</h5>{% endif %}
                                {% if slide.text %}<p class="mb-0">{{ slide.text }}</p>{% endif %}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>

                    {# Left/Right Arrows #}
                    <button class="carousel-control-prev" type="button" data-bs-target="#carousel-{{ loop.index }}" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carousel-{{ loop.index }}" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

{% elif block.type == 'alert_banner' %}
<section class="alert-block py-4 {{ block.theme }} text-white text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                {# Using a warning icon to draw the eye immediately #}
                <i class="bi-exclamation-triangle-fill fs-1 mb-2 d-block" aria-hidden="true"></i>
                <h2 class="h4 text-white mb-2">{{ block.headline }}</h2>
                <p class="mb-0 fs-5">{{ block.message }}</p>
            </div>
        </div>
    </div>
</section>

{% elif block.type == 'logo_cloud' %}
<section class="logo-cloud-block py-5 bg-white border-top border-bottom">
    <div class="container text-center">
        {% if block.title %}
        <p class="text-muted text-uppercase fw-bold mb-5" style="letter-spacing: 1px; font-size: 0.85rem;">{{ block.title }}</p>
        {% endif %}
        
        <div class="d-flex flex-wrap justify-content-center align-items-center gap-5">
            {% for logo in block.logo_list %}
            <div class="logo-wrapper">
                <img src="{{ logo.image }}" alt="{{ logo.alt }}" class="img-fluid" style="height: 60px; width: auto; object-fit: contain; filter: grayscale(100%) opacity(60%); transition: all 0.3s ease;">
            </div>
            {% endfor %}
        </div>
    </div>
</section>

                {% elif block.type == "testimonials" %}
                    <section class="testimonials-block py-5 {{ block.section_theme }}">
                        <div class="container">
                            <h2 class="text-center mb-5">{{ block.title }}</h2>
                            <div class="row g-4 justify-content-center">
                                {% for review in block.review_list %}
                                    <div class="col-md-6 col-lg-4">
                                        <div class="card h-100 border-0 shadow-sm p-4 text-center bg-white text-dark">
                                            <div class="text-warning mb-3 fs-5">★★★★★</div>
                                            <blockquote class="blockquote mb-3">
                                                <p class="fs-6">"{{ review.quote }}"</p>
                                            </blockquote>
                                            <figcaption class="blockquote-footer mb-0">
                                                {{ review.author }} <cite title="Source Title">on Google</cite>
                                            </figcaption>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </section>

                {% endif %}

            {% endfor %}
        {% endif %}
    </main>

    <footer class="bg-dark text-white py-5 mt-auto">
        <div class="container text-center">
            
            {% if site.footer_links %}
            <ul class="list-inline mb-4">
                {% for link in site.footer_links %}
                    <li class="list-inline-item mx-3">
                        <a href="{{ link.url }}" class="text-white text-decoration-none border-bottom border-secondary pb-1">{{ link.text }}</a>
                    </li>
                {% endfor %}
            </ul>
            {% endif %}

            {# Moved the social links inside the container so they stay centered! #}
            {% if site.social_links and site.social_links.length > 0 %}
            <div class="social-links-wrapper mb-4">
                {% for social in site.social_links %}
                {# Changed text-body-secondary to text-white so it shows up on the dark background #}
                <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" class="text-white text-decoration-none mx-2 fs-4 transition-all" aria-label="Follow us on {{ social.platform }}" title="{{ social.platform }}">
                    <i class="bi bi-{{ social.platform | lower }} hover-primary"></i>
                </a>
                {% endfor %}
            </div>
            {% endif %}

            <p class="mb-2">&copy; 2026 {{ site.name }}</p>
            <p class="small text-white-50">
                {{ site.footer_text }} | 
                <a href="mailto:{{ site.contactEmail }}" class="text-white-50">{{ site.contactEmail }}</a> | 
                {{ site.phone }}
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // --- Dark Mode Logic ---
        function toggleTheme() {
            const htmlTag = document.documentElement;
            const currentTheme = htmlTag.getAttribute('data-bs-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            htmlTag.setAttribute('data-bs-theme', newTheme);
            localStorage.setItem('siteTheme', newTheme);
            document.getElementById('theme-icon').textContent = newTheme === 'dark' ? '☀️' : '🌙';
        }

        // Apply saved theme on page load
        if (localStorage.getItem('siteTheme') === 'dark') {
            document.documentElement.setAttribute('data-bs-theme', 'dark');
            document.getElementById('theme-icon').textContent = '☀️';
        }

        // --- Text Resizer Logic ---
        let currentSize = 16; // Base size in pixels
        const rootElement = document.documentElement;

        function changeFontSize(direction) {
            currentSize += (direction * 2); // Goes up or down by 2px
            // Cap the sizes so it doesn't break the layout
            if (currentSize > 24) currentSize = 24; 
            if (currentSize < 14) currentSize = 14; 
            
            rootElement.style.fontSize = currentSize + 'px';
            localStorage.setItem('siteFontSize', currentSize);
        }

        function resetFontSize() {
            currentSize = 16;
            rootElement.style.fontSize = '16px';
            localStorage.removeItem('siteFontSize');
        }

        // Apply saved font size on load
        const savedSize = localStorage.getItem('siteFontSize');
        if (savedSize) {
            currentSize = parseInt(savedSize);
            rootElement.style.fontSize = currentSize + 'px';
        }
    </script>
</body>
</html>