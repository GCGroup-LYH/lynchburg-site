                            <img src="{{ slide.image }}" class="d-block w-100 object-fit-cover" style="height: 500px;" alt="{{ slide.alt }}">
                            
                            {# Optional Captions #}
                            {% if slide.heading or slide.text %}
                            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded px-3 py-2 mb-4">
                                {% if slide.heading %}<h5>{{ slide.heading }}</h5>{% endif %}
                                {% if slide.text %}<p class="mb-0">{{ slide.text }}</p>{% endif %}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>

                    {# Left/Right Arrows #}
                    <button class="carousel-control-prev" type="button" data-bs-target="#carousel-{{ loop.index }}" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carousel-{{ loop.index }}" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

