<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!--the following logic is intended to prevent bots from crawling the components library -->
    {% if title == "Component Library" %}
        <meta name="robots" content="noindex, nofollow">
        {% endif %}

    <title>{{ title }} | {{ site.name }}</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
        <div class ="container">
            <a class="navbar-brand fw-bold text-primary" href="/">{{ site.name }}</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link {% if page.url == '/' %}active fw-bold{% endif %}" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link {% if page.url == '/services/' %}active fw-bold{% endif %}" href="/services/">Services</a></li>
                    <li class="nav-item"><a class="nav-link {% if page.url == '/about/' %}active fw-bold{% endif %}" href="/about/">About</a></li>
                    <li class="nav-item"><a class="nav-link {% if page.url == '/contact/' %}active fw-bold{% endif %}" href="/contact/">Contact</a></li>
                    <li class="nav-item"><a class="nav-link {% if page.url == '/faq/' %}active fw-bold{% endif %}" href="/faq/">FAQ</a></li>

                    <li class="nav-item ms-lg-3">
                        <a class="btn btn-primary shadow-sm" href="{{ site.practiceLink  }}" target="_blank">
                            Client Portal
                            </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        {{ content | safe }}
    </main>

    <script>
        if (window.netlifyIdentity)   {
            window.netlifyIdentity.on("init", user => {
                if (!user) {
                    window.netlifyIdentity.on("login", () => {
                        document.location.href = "/admin/";
                    });
                }
            });
        }
        </script>
    <footer class="bg-dark text-white py-5 mt-5">
        <div class="container text-center">
        <p class="mb-2">&copy; 2026 {{ site.name }}</p>
        <p class="small text-white-50">Located in Lynchburg, VA | <a href="/contact/" class="text-white-50">Work with us</a></p>
        </div>
    </footer>

    <script src="http://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    </body>
    </html>