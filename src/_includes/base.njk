{% elif block.type == "contact_form" %}
<section class="contact-form-section my-5 {{ block.section_theme | default('bg-body') }}">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">

        <form id="mainContactForm" class="custom-minimal-form">
          <input type="hidden" name="form_type" value="{{ block.route_to }}">

          <div class="mb-4">
            <label for="main-name" class="visually-hidden">Contact name</label>
            <input type="text" class="form-control minimal-input" id="main-name" name="name" placeholder="Contact name" required>
          </div>

          <div class="mb-4">
            <label for="main-phone" class="visually-hidden">Phone</label>
            <input type="tel" class="form-control minimal-input" id="main-phone" name="phone" placeholder="Phone">
          </div>

          <div class="mb-4">
            <label for="main-email" class="visually-hidden">E-mail</label>
            <input type="email" class="form-control minimal-input" id="main-email" name="email" placeholder="E-mail" required>
          </div>

          <div class="mb-5">
            <label for="main-message" class="visually-hidden">Let's talk</label>
            <textarea class="form-control minimal-input" id="main-message" name="message" placeholder="Let's talk" rows="1" required></textarea>
          </div>

          <!-- Turnstile widget — replace YOUR_SITE_KEY -->
          <div class="cf-turnstile mb-4" data-sitekey="0x4AAAAAADBTgmkyOA3eOEqs" data-theme="light"></div>

          <div id="main-form-status" class="mb-3" role="alert" aria-live="polite"></div>

          <button type="submit" id="main-submit-btn" class="btn btn-{{ block.button_color | default('danger') }} w-100 py-3 rounded-2 fw-bold">
            Submit
          </button>
        </form>

        <script>
          document.getElementById('mainContactForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('main-submit-btn');
            const status = document.getElementById('main-form-status');
            
            btn.disabled = true;
            btn.textContent = 'Sending...';
            status.innerHTML = '';

            const formData = new FormData(this);

            try {
              const res = await fetch('/api/submit', {
                method: 'POST',
                body: formData
              });
              const data = await res.json();

              if (data.ok) {
                this.reset();
                if (window.turnstile) window.turnstile.reset();
                status.innerHTML = '<div class="alert alert-success">Thank you! We\'ll be in touch within 3 business days.</div>';
                btn.textContent = 'Sent!';
              } else {
                status.innerHTML = '<div class="alert alert-danger">Something went wrong. Please try again or call us directly.</div>';
                btn.disabled = false;
                btn.textContent = 'Submit';
                if (window.turnstile) window.turnstile.reset();
              }
            } catch(err) {
              status.innerHTML = '<div class="alert alert-danger">Network error. Please check your connection and try again.</div>';
              btn.disabled = false;
              btn.textContent = 'Submit';
              if (window.turnstile) window.turnstile.reset();
            }
          });
        </script>

      </div>
    </div>
  </div>
</section>

