---
layout: "base.njk"  # (Change this if your main layout has a different name!)
---

<article class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      {% if image %}
        <img src="{{ image }}" alt="{{ title }}" class="img-fluid rounded mb-4">
      {% endif %}

      <h1 class="mb-3">{{ title }}</h1>
      <p class="text-muted mb-4">By {{ author | default("Our Team") }} | {{ date | date }}</p>

      <div class="blog-content">
        {{ content | safe }}
      </div>

    </div>
  </div>
</article>