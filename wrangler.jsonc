{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lynchburg-site",
  "compatibility_date": "2025-09-27",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "_site",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
